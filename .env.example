# ── IA: Gemini (principal) + Claude Haiku (fallback) ──────────────────────────
# Gemini: misma key que GastoSmart
GEMINI_API_KEY=
# Claude Haiku: solo se usa si Gemini falla (opcional)
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5-20251001

# ── Gmail ──────────────────────────────────────────────────────────────────────
# credentials.json se descarga desde Google Cloud Console
GMAIL_CREDENTIALS_FILE=credentials.json
GMAIL_TOKEN_FILE=token.json

# Query para encontrar emails relevantes (ajustar según tu empresa)
GMAIL_QUERY=has:attachment (invoice OR factura OR boleta OR receipt OR cobro) newer_than:60d

# ── Procesamiento ──────────────────────────────────────────────────────────────
BATCH_SIZE=20
CHECK_INTERVAL_MINUTES=30
MAX_BODY_CHARS=3000
MAX_ATTACHMENTS=3

# ── Web app ────────────────────────────────────────────────────────────────────
WEB_HOST=127.0.0.1
WEB_PORT=5000
SECRET_KEY=cambia-esto-por-algo-seguro
ITEMS_PER_PAGE=50

# ── Logs ───────────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
DB_FILENAME=gastos.db
